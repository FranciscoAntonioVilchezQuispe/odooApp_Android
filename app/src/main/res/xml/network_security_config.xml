<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Allow cleartext HTTP for emulator and common local network IP patterns -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <!-- Replace with your PC IP if testing on real device -->
        <domain includeSubdomains="true">192.168.100.51</domain>
        <domain includeSubdomains="true">192.168.100.16</domain>
        <domain includeSubdomains="true">192.168.1.1</domain>
    </domain-config>
</network-security-config>