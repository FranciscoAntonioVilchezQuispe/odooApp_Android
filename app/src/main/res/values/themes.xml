<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema Base de la Aplicación -->
    <style name="Base.Theme.OdooApp" parent="Theme.Material3.Light.NoActionBar">
        <!-- Colores principales -->
        <item name="colorPrimary">@color/stack_blue_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/stack_teal_accent</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Colores de Superficie (Evita que Material 3 use colores dinámicos del sistema) -->
        <item name="colorSurface">@color/rigid_surface</item>
        <item name="colorOnSurface">@color/rigid_text_primary</item>
        <item name="colorSurfaceVariant">@color/rigid_background</item>
        <item name="colorOnSurfaceVariant">@color/rigid_text_secondary</item>
        <item name="android:windowBackground">@color/odoo_background</item>

        <!-- Configuración de Barras de Sistema -->
        <item name="android:statusBarColor">@color/stack_blue_primary</item>
        <item name="android:navigationBarColor">@android:color/black</item>

        <!-- Desactivar forzado de modo oscuro del sistema (Huawei/Honor/Samsung) -->
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="Theme.OdooApp" parent="Base.Theme.OdooApp" />
</resources>